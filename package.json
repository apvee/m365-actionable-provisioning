{
  "name": "spfx-actionable-provisioning-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Monorepo for Apvee M365 actionable provisioning packages and the SPFx demo app.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22.14.0 < 23.0.0"
  },
  "scripts": {
    "build": "npm run build:m365 && npm run build:spfx && npm run build:test-spfx",
    "build:m365": "npm run build -w @apvee/m365-actionable-provisioning",
    "build:spfx": "npm run build -w @apvee/spfx-m365-actionable-provisioning",
    "build:test-spfx": "npm run build -w test-spfx",
    "clean": "npm run clean --workspaces --if-present",
    "serve:test-spfx": "npm run serve -w test-spfx",
    "generate:barrels": "npx tsx scripts/generate-barrels.ts",
    "generate:barrels:dry": "npx tsx scripts/generate-barrels.ts --dry-run",
    "generate:barrels:strict": "npx tsx scripts/generate-barrels.ts --require-public"
  },
  "devDependencies": {
    "@microsoft/eslint-config-spfx": "1.21.1",
    "@microsoft/eslint-plugin-spfx": "1.21.1",
    "@microsoft/rush-stack-compiler-5.3": "0.1.0",
    "@microsoft/sp-build-web": "1.21.1",
    "@microsoft/sp-module-interfaces": "1.21.1",
    "@rushstack/eslint-config": "4.0.1",
    "@types/react": "17.0.45",
    "@types/react-dom": "17.0.17",
    "@types/webpack-env": "~1.15.2",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "4.3.0",
    "glob": "^13.0.1",
    "gulp": "4.0.2",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "~5.3.3"
  }
}
