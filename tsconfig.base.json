{
  "compilerOptions": {
    "target": "es2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react",
    "declaration": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "inlineSources": false,
    "noImplicitAny": true,
    "forceConsistentCasingInFileNames": true,
    "lib": [
      "es2019",
      "dom"
    ]
  }
}
